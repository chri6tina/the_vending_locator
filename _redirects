# Handle clean URLs (redirect to .html files)
/pricing /pricing.html 200
/services /services.html 200
/blog /blog.html 200
/contact /contact.html 200

# Handle blog post URLs - use 200 status for SPA routing
/blog/* /blog-post.html 200

# Redirect root to index
/ /index.html 200

# Handle .html extensions (serve directly)
/index.html /index.html 200
/pricing.html /pricing.html 200
/services.html /services.html 200
/blog.html /blog.html 200
/contact.html /contact.html 200

# Additional redirects for common variations
/pricing/ /pricing.html 200
/services/ /services.html 200
/blog/ /blog.html 200
/contact/ /contact.html 200

# Test page
/test-blog /test-blog.html 200

# Location pages - handle both the directory and individual location pages
/location /location/index.html 200
/location/ /location/index.html 200
/location/*.html /location/*.html 200

# Handle clean location URLs (without .html extension)
/location/* /location/*.html 200

# Redirect old directory to new location
/directory /location/ 301
/directory/ /location/ 301

# Redirect plural to singular for locations
/locations /location/ 301
/locations/ /location/ 301

# Fallback for any 404s
/* /index.html 404 